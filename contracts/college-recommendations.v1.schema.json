{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://halda.ai/contracts/college-recommendations.v1.schema.json",
  "title": "Halda college recommendation results",
  "description": "Payload emitted by the college_results SSE event. Factual fields must come from the attributed source; unavailable facts are null, never inferred.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event",
    "recommendation_set_id",
    "generated_at",
    "query",
    "colleges"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "event": {
      "const": "college_results"
    },
    "recommendation_set_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "query": {
      "$ref": "#/$defs/queryContext"
    },
    "colleges": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/collegeRecommendation"
      }
    }
  },
  "$defs": {
    "nullableNumber": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "nullableRate": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "queryContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "requested_program", "student_budget_usd"],
      "properties": {
        "text": {
          "type": "string"
        },
        "requested_program": {
          "type": ["string", "null"]
        },
        "student_budget_usd": {
          "$ref": "#/$defs/nullableNumber"
        }
      }
    },
    "collegeRecommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "college_id",
        "name",
        "location",
        "classification",
        "match_score",
        "match_reasons",
        "financials",
        "admissions",
        "outcomes",
        "program",
        "sources"
      ],
      "properties": {
        "college_id": {
          "type": "string",
          "description": "Stable institution identifier, preferably the federal UNITID.",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "classification": {
          "$ref": "#/$defs/classification"
        },
        "match_score": {
          "description": "Halda fit score, not an admission probability.",
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "match_reasons": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/matchReason"
          }
        },
        "financials": {
          "$ref": "#/$defs/financials"
        },
        "admissions": {
          "$ref": "#/$defs/admissions"
        },
        "outcomes": {
          "$ref": "#/$defs/outcomes"
        },
        "program": {
          "$ref": "#/$defs/program"
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceAttribution"
          }
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["city", "state"],
      "properties": {
        "city": {
          "type": ["string", "null"]
        },
        "state": {
          "type": ["string", "null"],
          "description": "Two-letter state or territory code when available."
        }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "reason", "basis"],
      "properties": {
        "label": {
          "enum": ["reach", "target", "likely", "unknown"]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "basis": {
          "enum": ["student_academic_profile", "admission_rate_only", "insufficient_data"]
        }
      }
    },
    "matchReason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "text", "evidence"],
      "properties": {
        "category": {
          "enum": ["academic", "financial", "program", "location", "outcomes", "culture"]
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": ["string", "null"],
          "description": "Short factual basis for the reason; null only for explicitly subjective culture-fit reasoning."
        }
      }
    },
    "financials": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "net_price",
        "student_budget",
        "budget_difference",
        "within_budget"
      ],
      "properties": {
        "currency": {
          "const": "USD"
        },
        "net_price": {
          "$ref": "#/$defs/nullableNumber"
        },
        "student_budget": {
          "$ref": "#/$defs/nullableNumber"
        },
        "budget_difference": {
          "type": ["number", "null"],
          "description": "student_budget minus net_price; positive means under budget."
        },
        "within_budget": {
          "type": ["boolean", "null"],
          "description": "Null when either net price or student budget is unavailable."
        }
      }
    },
    "admissions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["admission_rate"],
      "properties": {
        "admission_rate": {
          "$ref": "#/$defs/nullableRate"
        }
      }
    },
    "outcomes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["graduation_rate", "median_earnings_10yr"],
      "properties": {
        "graduation_rate": {
          "$ref": "#/$defs/nullableRate"
        },
        "median_earnings_10yr": {
          "$ref": "#/$defs/nullableNumber"
        }
      }
    },
    "program": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested", "status", "cip_code"],
      "properties": {
        "requested": {
          "type": ["string", "null"]
        },
        "status": {
          "enum": ["available", "unavailable", "unknown"]
        },
        "cip_code": {
          "type": ["string", "null"]
        }
      }
    },
    "sourceAttribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "retrieved_at", "fields"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
